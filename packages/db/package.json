{
  "name": "@workspace/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./schema": {
      "development": "./src/schema/index.ts",
      "types": "./src/schema/index.ts",
      "default": "./dist/schema/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "db:generate": "NODE_OPTIONS=--conditions=development dotenv -e ../../apps/api/.env -- drizzle-kit generate",
    "db:migrate": "dotenv -e ../../apps/api/.env -- tsx --conditions=development src/migrate.ts",
    "db:studio": "NODE_OPTIONS=--conditions=development dotenv -e ../../apps/api/.env -- drizzle-kit studio",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run src --exclude **/*.integration.test.ts --passWithNoTests",
    "test:integration": "vitest run src/schema/support.integration.test.ts"
  },
  "dependencies": {
    "@workspace/domain": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^11.14.0",
    "@types/pg": "^8.20.0",
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.4",
    "tsup": "^8.5.1",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  }
}
