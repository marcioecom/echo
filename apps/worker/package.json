{
  "name": "@workspace/worker",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsup",
    "dev": "tsx watch --conditions=development --env-file=.env src/index.ts",
    "lint": "eslint . --max-warnings 0",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run src --exclude **/*.integration.test.ts",
    "test:integration": "vitest run src/app.integration.test.ts"
  },
  "dependencies": {
    "@workspace/config": "workspace:*",
    "@workspace/db": "workspace:*",
    "bullmq": "^5.0.0",
    "fastify": "^5.0.0",
    "ioredis": "^5.0.0",
    "pino-pretty": "^13.0.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^11.0.0",
    "@types/node": "^22.0.0",
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "eslint": "^9.0.0",
    "testcontainers": "^11.0.0",
    "tsup": "^8.5.0",
    "tsx": "^4.0.0",
    "typescript": "^5",
    "vitest": "^4.0.0"
  }
}
