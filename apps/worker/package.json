{
  "name": "@workspace/worker",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsup",
    "dev": "tsx watch --conditions=development --env-file=.env src/main.ts",
    "lint": "eslint . --max-warnings 0",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run src --exclude **/*.integration.test.ts",
    "test:integration": "vitest run src/app.integration.test.ts"
  },
  "dependencies": {
    "@getworkbench/fastify": "^0.9.1",
    "@workspace/config": "workspace:*",
    "@workspace/db": "workspace:*",
    "@workspace/domain": "workspace:*",
    "@workspace/email": "workspace:*",
    "@workspace/jobs": "workspace:*",
    "@workspace/logger": "workspace:*",
    "bullmq": "^5.80.9",
    "fastify": "^5.10.0",
    "ioredis": "^5.11.1",
    "pino-pretty": "^13.1.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^11.14.0",
    "@types/node": "^22.20.1",
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "eslint": "^9.39.4",
    "testcontainers": "^11.14.0",
    "tsup": "^8.5.1",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  }
}
