{
  "name": "@workspace/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "auth:schema:generate": "NODE_OPTIONS=--conditions=development auth generate --config src/modules/auth/auth-schema-config.ts --output ../../packages/db/src/schema/auth.ts --yes",
    "build": "tsup",
    "dev": "tsx watch --conditions=development --env-file=.env src/index.ts",
    "lint": "eslint . --max-warnings 0",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run src --exclude **/*.integration.test.ts",
    "test:integration": "vitest run src/app.integration.test.ts"
  },
  "dependencies": {
    "@better-auth/drizzle-adapter": "^1.0.0",
    "@workspace/config": "workspace:*",
    "@workspace/db": "workspace:*",
    "@workspace/domain": "workspace:*",
    "better-auth": "^1.0.0",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.0.0",
    "ioredis": "^5.0.0",
    "pino-pretty": "^13.0.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "@testcontainers/postgresql": "^11.0.0",
    "auth": "^1.6.23",
    "eslint": "^9.0.0",
    "testcontainers": "^11.0.0",
    "tsup": "^8.5.0",
    "tsx": "^4.0.0",
    "typescript": "^5",
    "vitest": "^4.0.0"
  }
}
