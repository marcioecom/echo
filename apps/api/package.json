{
  "name": "@workspace/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "auth:schema:generate": "NODE_OPTIONS='--conditions=development --env-file=.env' auth generate --config src/modules/auth/auth-cli-config.ts --output ../../packages/db/src/schema/auth.ts --yes",
    "build": "tsup",
    "dev": "tsx watch --conditions=development --env-file=.env src/main.ts",
    "lint": "eslint . --max-warnings 0",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run src --exclude **/*.integration.test.ts",
    "test:integration": "vitest run integration.test"
  },
  "dependencies": {
    "@better-auth/drizzle-adapter": "^1.6.23",
    "@fastify/cors": "^11.2.0",
    "@workspace/auth": "workspace:*",
    "@workspace/config": "workspace:*",
    "@workspace/db": "workspace:*",
    "@workspace/domain": "workspace:*",
    "@workspace/jobs": "workspace:*",
    "@workspace/logger": "workspace:*",
    "better-auth": "^1.6.23",
    "bullmq": "^5.80.9",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.10.0",
    "ioredis": "^5.11.1",
    "pino": "^9.14.0",
    "pino-pretty": "^13.1.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^11.14.0",
    "@types/node": "^22.20.1",
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "auth": "^1.6.23",
    "eslint": "^9.39.4",
    "testcontainers": "^11.14.0",
    "tsup": "^8.5.1",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  }
}
