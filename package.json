{
  "name": "echo",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "auth:schema:generate": "pnpm --filter @workspace/api auth:schema:generate",
    "build": "turbo build",
    "db:generate": "pnpm --filter @workspace/db db:generate",
    "db:migrate": "pnpm --filter @workspace/db db:migrate",
    "db:studio": "pnpm --filter @workspace/db db:studio",
    "dev": "turbo dev",
    "infra:down": "docker compose down",
    "infra:up": "docker compose up -d --wait",
    "lint": "turbo lint",
    "format": "turbo format",
    "test": "turbo test",
    "test:integration": "turbo test:integration",
    "typecheck": "turbo typecheck"
  },
  "devDependencies": {
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "turbo": "^2.10.5",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@11.17.0",
  "engines": {
    "node": ">=20"
  }
}
